rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'sameer781998@gmail.com';
    }

    function isOwnerByUidOrEmail(ownerValue) {
      return signedIn() && (
        ownerValue == request.auth.uid ||
        (request.auth.token.email != null && ownerValue == request.auth.token.email)
      );
    }

    function isMember(memberIds) {
      return signedIn() && request.auth.uid in memberIds;
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId));
    }

    function groupMembers(groupId) {
      return groupDoc(groupId).data.members;
    }

    function isGroupMember(groupId) {
      return isMember(groupMembers(groupId));
    }

    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // Invite codes: any signed-in user can read (to join by code);
    // only the group owner or admin can create/update
    match /invites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn() && (
        get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.createdBy == request.auth.uid
        || isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // Groups: signed-in creator can create; only members can read.
    match /groups/{groupId} {
      allow read: if isMember(resource.data.members);
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members
        && request.resource.data.memberDetails is map;
      // Owner/admin can do any update (incl. removing members, updating inviteCode).
      // Other members can only append new members (createdBy/name/createdAt immutable).
      allow update: if (isOwnerByUidOrEmail(resource.data.createdBy) || isAdmin()) ||
        (isMember(resource.data.members)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.name == resource.data.name
          && request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isOwnerByUidOrEmail(resource.data.createdBy) || isAdmin();

      // Expenses sub-collection
      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.description is string
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.paidBy in groupMembers(groupId);
        allow update, delete: if isOwnerByUidOrEmail(groupDoc(groupId).data.createdBy)
          || isAdmin()
          || request.auth.uid == resource.data.createdBy;
      }

      // Settlements sub-collection
      match /settlements/{settlementId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.recordedBy == request.auth.uid
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.paidBy in groupMembers(groupId)
          && request.resource.data.paidTo in groupMembers(groupId);
        allow update, delete: if isOwnerByUidOrEmail(groupDoc(groupId).data.createdBy) || isAdmin();
      }
    }
  }
}
